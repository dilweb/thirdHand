# Telegram Bot
BOT_TOKEN=
ADMIN_IDS=[123456789]

# Database (localhost for local dev, overridden in docker-compose)
DATABASE_URL=postgresql+asyncpg://thirdhand:thirdhand@localhost:5434/thirdhand
DATABASE_URL_SYNC=postgresql://thirdhand:thirdhand@localhost:5434/thirdhand

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM
OPENROUTER_API_KEY=sk-or-v1-

DEFAULT_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
REASONING_MODEL=google/gemini-2.5-flash-lite-preview-09-2025

INTENT_MODEL=deepseek/deepseek-v4-flash
BROWSER_MODEL=deepseek/deepseek-v4-flash
SEARCH_MODEL=deepseek/deepseek-v4-flash

CHAT_MODEL=deepseek/deepseek-v4-flash
PROFILE_MODEL=deepseek/deepseek-v4-flash
SUMMARY_MODEL=deepseek/deepseek-v4-flash

PICTURE_RECOGNITION_MODEL=openai/gpt-4o-mini

# Search
TAVILY_API_KEY=tvly-dev-

# Browser automation
BROWSER_HEADLESS=true
BROWSER_PROFILE_DIR=.browser-profile
# LLM step deadline (seconds): one model call can run up to this long (default 690 ≈ 90s + 10m)
BROWSER_LLM_STEP_TIMEOUT_SECONDS=690
# Progress log interval while waiting for the model (seconds)
BROWSER_LLM_STEP_HEARTBEAT_SECONDS=10
# Max interactive elements in inspect_page snapshots (raise if CTAs are missing from interactive[])
BROWSER_INSPECT_INTERACTIVE_LIMIT=180
BROWSER_SITE_CREDENTIALS_JSON=
# Verbose browser trace in Telegram summaries when blocked (default: off)
BROWSER_REPORT_VERBOSE=false

# Timezone
DEFAULT_TIMEZONE=Asia/Almaty