# Telegram Bot
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=[123456789]

# Database
DATABASE_URL=postgresql+asyncpg://thirdhand:thirdhand@localhost:5432/thirdhand
DATABASE_URL_SYNC=postgresql://thirdhand:thirdhand@localhost:5432/thirdhand

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM
OPENROUTER_API_KEY=sk-or-v1-
DEFAULT_MODEL=qwen/qwen3.6-plus
INTENT_MODEL=
BROWSER_MODEL=
CHAT_MODEL=
SEARCH_MODEL=
PROFILE_MODEL=
SUMMARY_MODEL=
PICTURE_RECOGNITION_MODEL=

# Search
TAVILY_API_KEY=your_tavily_api_key_here

# Browser automation
BROWSER_HEADLESS=true
BROWSER_PROFILE_DIR=.browser-profile
# LLM step deadline (seconds): one model call can run up to this long (default 690 ≈ 90s + 10m)
BROWSER_LLM_STEP_TIMEOUT_SECONDS=690
# Progress log interval while waiting for the model (seconds)
BROWSER_LLM_STEP_HEARTBEAT_SECONDS=10
# Max interactive elements in inspect_page snapshots (raise if CTAs are missing from interactive[])
BROWSER_INSPECT_INTERACTIVE_LIMIT=180
BROWSER_SITE_CREDENTIALS_JSON=
# Verbose browser trace in Telegram summaries when blocked (default: off)
BROWSER_REPORT_VERBOSE=false

# Timezone
DEFAULT_TIMEZONE=Asia/Almaty
